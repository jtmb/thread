# Thread — Environment Variables
# Copy this to .env and edit for your setup.
# Docker Compose picks up .env automatically.
# All values shown are the defaults; uncomment and change what you need.

## ── Networking ──────────────────────────────────────────────────────────────
# THREAD_HOST=0.0.0.0          # Interface to bind to
# THREAD_PORT=5000              # Port the HTTP server listens on

## ── Storage ─────────────────────────────────────────────────────────────────
# THREAD_DB_PATH=data/thread.db  # SQLite database file
# THREAD_GIT_BASE=data/git/      # Per-session Git tracking repos

## ── Logging ─────────────────────────────────────────────────────────────────
# THREAD_LOG_LEVEL=INFO          # DEBUG | INFO | WARNING | ERROR | CRITICAL
# THREAD_LOG_FILE=               # Log file path (empty = stderr)
# THREAD_DEBUG=false             # true|1|yes = Flask debug mode (never in production)

## ── Thread Pool ─────────────────────────────────────────────────────────────
# THREAD_POOL_SIZE=12            # WSGI worker threads
# THREAD_POOL_TIMEOUT=10         # Max seconds waiting for a DB connection

## ── Caching ─────────────────────────────────────────────────────────────────
# THREAD_CACHE_SIZE=512          # Session name→id LRU cache entries
# THREAD_SEARCH_CACHE_SIZE=128   # Max cached FTS5 search results
# THREAD_SEARCH_CACHE_TTL=5      # How long search results stay cached (seconds)
# THREAD_TAG_CACHE_TTL=30        # How long tag lists stay cached (seconds)

## ── Query Limits ────────────────────────────────────────────────────────────
# THREAD_MAX_SEARCH_RESULTS=100  # Max entries returned by FTS5 search
# THREAD_DEFAULT_PAGE_SIZE=50    # Default entries per page for cursor pagination
# THREAD_MAX_PAGE_SIZE=200       # Hard cap on entries per page (≤ 1000)
# THREAD_MAX_CONTENT_LENGTH=100000  # Max chars per entry (100KB)
# THREAD_MAX_UPLOAD_SIZE=314572800   # Max file upload size in bytes (300MB — Docker default)
#                                   # Bare-metal default is 4194304 (4MB) — raise for transcripts
